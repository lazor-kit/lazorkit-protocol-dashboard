{
  "name": "lazorkit-protocol-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "tsx api/dev-server.ts",
    "db:reset-analytics": "tsx scripts/resetAnalytics.ts",
    "indexer:mainnet": "tsx scripts/runIndexer.ts mainnet",
    "indexer:devnet": "tsx scripts/runIndexer.ts devnet",
    "indexer:all": "tsx scripts/runIndexer.ts all",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:api": "tsc --noEmit --target ES2022 --module ESNext --moduleResolution Bundler --types node --skipLibCheck api/dev-server.ts api/protocol-stats.ts api/dashboard.ts api/cron/indexer.ts api/_lib/analytics.ts api/_lib/database.ts api/_lib/env.ts api/_lib/indexer.ts api/_lib/protocolStats.ts api/_lib/transactionParser.ts scripts/loadApiEnv.ts scripts/resetAnalytics.ts scripts/runIndexer.ts vite.config.ts"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "supabase": "^2.101.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
